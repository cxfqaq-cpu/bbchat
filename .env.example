# Supabase（必填）
SUPABASE_URL=https://你的项目.supabase.co
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_key
SUPABASE_ANON_KEY=你的_anon_key

# 管理后台密码（必填，部署后请修改）
ADMIN_PASSWORD=bbchat-admin-请改成强密码

# 邮件验证码（可选，不配置则在开发模式显示验证码）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=bbchat <noreply@yourdomain.com>
